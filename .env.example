# ─── Slack 설정 ──────────────────────────────────────────
# Slack Bot Token (xoxb-로 시작)
# Slack 앱 > OAuth & Permissions > Bot User OAuth Token
SLACK_BOT_TOKEN=xoxb-your-bot-token-here

# Slack 채널 ID (C로 시작)
# 기본 채널 (ask/show 레이블 MR 알림)
SLACK_CHANNEL=C04XXXXXXX
# 배포 채널 (일반 MR 알림)
SLACK_CHANNEL_SHIP=C05XXXXXXX

# 팀 멘션 (선택, 기본: @fe3)
# 실제 Slack 멘션은 <!subteam^SUBTEAM_ID> 형식
# SLACK_TEAM_MENTION=@fe3

# ─── GitLab 설정 ─────────────────────────────────────────
# GitLab Webhook Secret Token (선택)
GITLAB_WEBHOOK_SECRET=

# GitLab MR 타겟 브랜치
GITLAB_TARGET_BRANCH=develop

# ─── n8n 설정 ────────────────────────────────────────────
# n8n 포트
N8N_PORT=5678
WEBHOOK_URL=http://localhost:5678/

# Code 노드에서 Node.js 내장 모듈 허용
NODE_FUNCTION_ALLOW_BUILTIN=fs,path,child_process,https,http,url,dgram

# n8n 타임아웃 설정 (Kombai 실행이 20-30분 소요)
N8N_RUNNERS_TASK_TIMEOUT=1800
N8N_RUNNERS_HEARTBEAT_INTERVAL=120
EXECUTIONS_TIMEOUT=3600
EXECUTIONS_TIMEOUT_MAX=7200

# ─── Figma 마크업 파이프라인 ─────────────────────────────
# Kombai PoC 디렉토리 (PROJECT_ROOT 기준 상대경로)
KOMBAI_POC_DIR=../your-project/scripts/kombai-poc

# 프로젝트 루트 (git 작업 경로)
PROJECT_ROOT=../your-project

# ─── AI 이미지 생성 ───────────────────────────────
# ComfyUI 서버 (같은 LAN)
COMFYUI_HOST=192.168.XXX.XXX
COMFYUI_PORT=8188
# AI 이미지 저장 경로
AI_IMAGES_DIR=~/ai-images
# 이미지 서빙 베이스 URL (터널)
AI_IMAGE_BASE_URL=https://your-tunnel-url.example.com
# WoL (Wake-on-LAN) — ComfyUI 서버 자동 기동
WOL_MAC_ADDRESS=XX:XX:XX:XX:XX:XX
WOL_BROADCAST=192.168.XXX.255
