{
  "id": "1",
  "name": "GitLab MR → Slack 알림",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "POST",
        "path": "gitlab-mr-webhook",
        "options": {
          "responseMode": "onReceived",
          "responseData": "allEntries"
        }
      },
      "id": "webhook-trigger",
      "name": "GitLab Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [240, 300],
      "webhookId": "gitlab-mr-webhook"
    },
    {
      "parameters": {
        "jsCode": "__PREPARE_MESSAGE_CODE__"
